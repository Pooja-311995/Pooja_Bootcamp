# Contentstack Configuration for GRABO Coffee Shop
# Copy this file to .env and fill in your actual values

# Required: Your Contentstack API Key
REACT_APP_CONTENTSTACK_API_KEY=your_api_key_here

# Required: Your Contentstack Delivery Token  
REACT_APP_CONTENTSTACK_DELIVERY_TOKEN=your_delivery_token_here

# Optional: Environment (defaults to 'development')
REACT_APP_CONTENTSTACK_ENVIRONMENT=development

# Optional: Region (defaults to 'US')
REACT_APP_CONTENTSTACK_REGION=US

REACT_APP_CONTENTSTACK_PERSONALIZE_PROJECT_UID=your_project_uid

# Optional: Lytics tag script URL. Defaults to the project tag if unset.
# REACT_APP_LYTICS_TAG_SRC=https://c.lytics.io/api/tag/<your_account_id>/latest.min.js
# Optional: set to true to load Lytics during npm start (development). Restart dev server after changing.
# REACT_APP_LYTICS_ENABLE_IN_DEV=true

# Production builds use .env.production (see GENERATE_SOURCEMAP there).

# Note: In React, all client-side environment variables must be prefixed with REACT_APP_
# These variables will be visible in the browser, so only use public tokens!
