# Production build: omit app source maps and skip source-map-loader (avoids noisy
# "Failed to parse source map" warnings from packages that ship broken maps, e.g.
# @contentstack/personalize-edge-sdk). Set to true if you need deployable .map files.
GENERATE_SOURCEMAP=false

# Ensure Lytics runs in production bundles (helps if a host’s build ever leaves NODE_ENV non-production).
REACT_APP_LYTICS_ENABLE=true
